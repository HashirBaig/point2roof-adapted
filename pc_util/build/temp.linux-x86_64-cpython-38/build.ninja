ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/nvidia/bin/nvcc

cflags = -pthread -Wno-unused-result -Wsign-compare -DNDEBUG -g -fwrapv -O2 -Wall -g -fstack-protector-strong -Wformat -Werror=format-security -g -fwrapv -O2 -fPIC -I/data/private/research/Point2Roof/.venv/lib/python3.8/site-packages/torch/include -I/data/private/research/Point2Roof/.venv/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/data/private/research/Point2Roof/.venv/lib/python3.8/site-packages/torch/include/TH -I/data/private/research/Point2Roof/.venv/lib/python3.8/site-packages/torch/include/THC -I/usr/local/nvidia/include -I/data/private/research/Point2Roof/.venv/include -I/usr/include/python3.8 -c
post_cflags = -g -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=pc_util -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++14
cuda_cflags = -I/data/private/research/Point2Roof/.venv/lib/python3.8/site-packages/torch/include -I/data/private/research/Point2Roof/.venv/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/data/private/research/Point2Roof/.venv/lib/python3.8/site-packages/torch/include/TH -I/data/private/research/Point2Roof/.venv/lib/python3.8/site-packages/torch/include/THC -I/usr/local/nvidia/include -I/data/private/research/Point2Roof/.venv/include -I/usr/include/python3.8 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -O2 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=pc_util -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_86,code=compute_86 -gencode=arch=compute_86,code=sm_86 -std=c++14
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags





build /data/private/research/Point2Roof/pc_util/build/temp.linux-x86_64-cpython-38/src/ball_query.o: compile /data/private/research/Point2Roof/pc_util/src/ball_query.cpp
build /data/private/research/Point2Roof/pc_util/build/temp.linux-x86_64-cpython-38/src/ball_query_gpu.o: cuda_compile /data/private/research/Point2Roof/pc_util/src/ball_query_gpu.cu
build /data/private/research/Point2Roof/pc_util/build/temp.linux-x86_64-cpython-38/src/cluster.o: compile /data/private/research/Point2Roof/pc_util/src/cluster.cpp
build /data/private/research/Point2Roof/pc_util/build/temp.linux-x86_64-cpython-38/src/cluster_gpu.o: cuda_compile /data/private/research/Point2Roof/pc_util/src/cluster_gpu.cu
build /data/private/research/Point2Roof/pc_util/build/temp.linux-x86_64-cpython-38/src/group_points.o: compile /data/private/research/Point2Roof/pc_util/src/group_points.cpp
build /data/private/research/Point2Roof/pc_util/build/temp.linux-x86_64-cpython-38/src/group_points_gpu.o: cuda_compile /data/private/research/Point2Roof/pc_util/src/group_points_gpu.cu
build /data/private/research/Point2Roof/pc_util/build/temp.linux-x86_64-cpython-38/src/interpolate.o: compile /data/private/research/Point2Roof/pc_util/src/interpolate.cpp
build /data/private/research/Point2Roof/pc_util/build/temp.linux-x86_64-cpython-38/src/interpolate_gpu.o: cuda_compile /data/private/research/Point2Roof/pc_util/src/interpolate_gpu.cu
build /data/private/research/Point2Roof/pc_util/build/temp.linux-x86_64-cpython-38/src/pointnet2_api.o: compile /data/private/research/Point2Roof/pc_util/src/pointnet2_api.cpp
build /data/private/research/Point2Roof/pc_util/build/temp.linux-x86_64-cpython-38/src/sampling.o: compile /data/private/research/Point2Roof/pc_util/src/sampling.cpp
build /data/private/research/Point2Roof/pc_util/build/temp.linux-x86_64-cpython-38/src/sampling_gpu.o: cuda_compile /data/private/research/Point2Roof/pc_util/src/sampling_gpu.cu







